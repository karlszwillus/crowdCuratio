		-
			message: '#^Property App\\Http\\Controllers\\Auth\\MyCustomWelcomeNotification\:\:\$firstName is never read, only written\.$#'
			identifier: property.onlyWritten
			count: 1
			path: app/Http/Controllers/Auth/MyCustomWelcomeNotification.php

