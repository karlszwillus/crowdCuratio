APP_NAME=crowdCuratio
APP_ENV=local
APP_KEY=
# APP_DEBUG=true ist NUR für lokale Entwicklung vorgesehen.
# In Produktion muss APP_DEBUG=false sein — sonst werden Stacktraces
# (inkl. potenziell sensibler Daten) öffentlich, und Ignition-CVEs
# können ausgenutzt werden.
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=crowd_curatio
DB_USERNAME=sail
# DB_PASSWORD muss gesetzt sein, sonst startet der MySQL-Container nicht
# (siehe docker-compose.yml). Der unten gesetzte Wert ist NUR für lokale
# Entwicklung gedacht. In Produktion durch ein starkes, einmaliges
# Passwort ersetzen.
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Admin-Seeder (CreateAdminUserSeeder)
# Beim ersten `php artisan db:seed` muss ein Admin-Konto angelegt werden.
# Die folgenden Werte setzen, dann seeden. Nach erfolgreichem Seed
# können (sollten!) die Werte aus der laufenden .env wieder entfernt
# werden, damit das Initial-Passwort nicht aus dem Environment
# rekonstruierbar bleibt.
ADMIN_NAME=Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
